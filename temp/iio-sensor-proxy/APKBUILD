# Forked from Alpine to add Qualcomm SSC support with libssc
maintainer="Dylan Van Assche <me@dylanvanassche.be>"
pkgname=iio-sensor-proxy
_pkgver=3.8
pkgver=9999$_pkgver
pkgrel=6
pkgdesc="IIO sensors to D-Bus proxy"
url="https://gitlab.freedesktop.org/hadess/iio-sensor-proxy"
arch="aarch64"
license="GPL-2.0-or-later"
depends="dbus"
makedepends="
	eudev-dev
	glib-dev
	libgudev-dev
	meson
	polkit-dev
	libssc-dev>=0.2.1
	"
subpackages="$pkgname-openrc $pkgname-systemd $pkgname-udev"
builddir="$srcdir/$pkgname-$_pkgver"
source="https://gitlab.freedesktop.org/hadess/iio-sensor-proxy/-/archive/$_pkgver/iio-sensor-proxy-$_pkgver.tar.gz
	iio-sensor-proxy.initd
	system-iio-sensor-proxy.service.d-hexagonrpcd.conf
	0001-iio-sensor-proxy-depend-on-libssc.patch
	0002-proximity-support-SSC-proximity-sensor.patch
	0003-light-support-SSC-light-sensor.patch
	0004-accelerometer-support-SSC-accelerometer-sensor.patch
	0005-compass-support-SSC-compass-sensor.patch
	0006-data-iio-sensor-proxy.service.in-add-AF_QIPCRTR.patch
	0007-drv-ssc-implement-set_polling.patch
	0008-tests-integration-test-add-SSC-sensors.patch
	0009-CI-add-libssc-build.patch
	0010-ssc-Simplify-sensor-handling.patch
	0001-WIP-iio-sensor-proxy.c-Do-not-exit-based-on-sensor-e.patch
	0013-integration-test-add-test-for-sensors-that-report-no.patch
	0001-iio-sensor-proxy-register-DBus-objects-after-client-.patch
	"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dssc-support=enabled \
		-Dsystemdsystemunitdir=/usr/lib/systemd/system \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname

	install -Dm644 "$srcdir"/system-iio-sensor-proxy.service.d-hexagonrpcd.conf \
		"$pkgdir"/usr/lib/systemd/system/iio-sensor-proxy.service.d/hexagonrpcd.conf
}

