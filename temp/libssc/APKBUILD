# Forked from Alpine to test the next libssc release
maintainer="Dylan Van Assche <dylan@postmarketos.org>"
pkgname=libssc
pkgver=99990.3.0
pkgrel=0
_commit="6e6d92dd1cdadfd5ad62e8f1d8f2333cd27b00c9"
pkgdesc="Library to expose Qualcomm Sensor Core sensors"
url="https://codeberg.org/DylanVanAssche/libssc"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	eudev-dev
	glib-dev
	libgudev-dev
	linux-headers
	libqmi-dev
	meson
	protobuf-c-dev
	protobuf-dev
	python3-dev
	py3-gobject3
	py3-protobuf
	qrtr-libs
"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-pyc"
builddir="$srcdir/$pkgname"
source="$pkgname-$_commit.tar.gz::https://codeberg.org/dylanvanassche/libssc/archive/$_commit.tar.gz
"

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

check() {
	meson test --print-errorlogs -C output
}

sha512sums="
