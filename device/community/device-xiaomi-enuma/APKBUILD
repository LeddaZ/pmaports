# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: Dawid Wróbel <me@dawidwrobel.com>
pkgname=device-xiaomi-enuma
pkgdesc="Xiaomi Mi Pad 5 Pro 5G"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	linux-postmarketos-qcom-sm8250
	alsa-ucm-conf
	hexagonrpcd>=0.3.2-r3
	make-dynpart-mappings
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-qbootctl
	qmi-utils
"
makedepends="devicepkg-dev"
source="
	81-libssc-xiaomi-enuma.rules
	alsa-ucm-conf/enuma.conf
	alsa-ucm-conf/HiFi.conf
	deviceinfo
	firmware.files
	hexagonrpcd.confd
	modules-initfs
"

subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-openrc
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/firmware.files \
		-t "$pkgdir"/usr/share/mkinitfs/files

	# device-specific alsa ucm conf
	install -Dm644 "$srcdir/enuma.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/enuma/enuma.conf"

	install -Dm644 "$srcdir/HiFi.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Xiaomi/enuma/HiFi.conf"

	mkdir -p "$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250"
	ln -s ../../Xiaomi/enuma/enuma.conf \
		"$pkgdir/usr/share/alsa/ucm2/conf.d/sm8250/Xiaomi Mi Pad 5 Pro.conf"

	install -Dm644 "$srcdir"/81-libssc-xiaomi-enuma.rules \
		"$pkgdir"/usr/lib/udev/rules.d/81-libssc-xiaomi-enuma.rules

	install -Dm644 "$srcdir"/hexagonrpcd.confd \
		"$pkgdir"/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf
}

nonfree_firmware() {
	pkgdesc="Firmware for GPU, WiFi, etc."
	depends="
		firmware-xiaomi-elish-adreno
		firmware-xiaomi-elish-adsp
		firmware-xiaomi-elish-cdsp
		firmware-xiaomi-elish-cirrus
		firmware-xiaomi-elish-hexagonfs
		firmware-xiaomi-elish-initramfs
		firmware-xiaomi-elish-ipa
		firmware-xiaomi-elish-slpi
		firmware-xiaomi-elish-venus
		firmware-xiaomi-enuma-touchscreen
		firmware-xiaomi-enuma-x55m
		linux-firmware-ath11k
		linux-firmware-qca
		"
	mkdir "$subpkgdir"
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	install="$subpkgname.post-install $subpkgname.post-upgrade"
	depends="hexagonrpcd-openrc"

	mkdir -p "$subpkgdir"
}

