6faf55b7804e4cc0ceda959b3c19010d0052c18cc1bc1fc4364ddc65ec6d8715175d754b8d4aa837e23a66150b48ebc94c1c16a9ee0b405e824fae1fb6e5ae32  30-dsp-firmware.files
"
