# Maintainer: M0Rf30 <morf3089@gmail.com>
# Co-Maintainer: Ultra-azu <ultra.public@proton.me>
# Co-Maintainer: Barnabas Czeman <barnabas.czeman@postmarketos.org>
# Kernel config based on: defconfig, msm8953.config, and device configs

_flavor="postmarketos-qcom-msm8953"
pkgname=linux-$_flavor
pkgver=6.16.3
pkgrel=2
pkgdesc="Close to mainline linux kernel for Qualcomm Snapdragon MSM8953"
arch="aarch64"
_carch="arm64"
url="https://github.com/msm8953-mainline/linux"
license="GPL-2.0-only"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-community
"
_depends_dev="
	perl
	gmp-dev
	mpc1-dev
	mpfr-dev
	elfutils-dev
	bash
	flex
	bison
	zstd
"

makedepends="
	bash
	bison
	findutils
	flex
	openssl-dev
	perl
	postmarketos-installkernel
	python3
	mawk
"

_tag="$pkgver-r0"

source="
	$pkgname-v$_tag.tar.gz::$url/archive/v$_tag.tar.gz
	config-$_flavor.aarch64
"
subpackages="$pkgname-dev:_dev:$CBUILD_ARCH"

builddir="$srcdir/linux-$_tag"
_kernelobjectdir="$builddir/build-$_flavor"

prepare() {
	default_prepare
	mkdir $_kernelobjectdir
	cp "$srcdir/config-$_flavor.$arch" "$_kernelobjectdir/.config"
}

build() {
	unset LDFLAGS
	# Generate appropriate Makefiles in subdir.
	make -C "." O="$_kernelobjectdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-$_flavor" \
		olddefconfig
	cd "$_kernelobjectdir"
	make ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-$_flavor"
}

package() {
	mkdir -p "$pkgdir"/boot

	cd "$_kernelobjectdir"
	make zinstall modules_install dtbs_install \
		ARCH="$_carch" \
		INSTALL_PATH="$pkgdir"/boot \
		INSTALL_MOD_PATH="$pkgdir" \
		INSTALL_MOD_STRIP=1 \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs"
	rm -f "$pkgdir"/lib/modules/*/build "$pkgdir"/lib/modules/*/source

	install -Dm644 "$_kernelobjectdir/include/config/kernel.release" \
		"$pkgdir/usr/share/kernel/$_flavor/kernel.release"
}

_dev() {
	# This is an adaptation of upstream Alpine Linux _dev() on linux-lts
	# APKBUILD, which is itself an adaptation of what ubuntu does.
	# The goal is to have the minimal set of files to compile out-of-tree modules.
	cd "$builddir"
	local _abi_release="$(make -C "$_kernelobjectdir" -s kernelrelease)"

	pkgdesc="Headers and script for third party modules for $_flavor kernel"
	depends="$_depends_dev"
	local _kernelheaderdir="$subpkgdir"/usr/src/linux-headers-"$_abi_release"

	# From now on, minus variable names substitutions, the rest of this
	# function is taken from Alpine APKBUILD for linux-lts available here:
	# https://git.alpinelinux.org/aports/tree/main/linux-lts/APKBUILD#n268

	# first we import config, run prepare to set up for building
	# external modules, and create the scripts
	mkdir -p "$_kernelheaderdir"
	cp -a "$_kernelobjectdir"/.config "$_kernelheaderdir"/

	install -D -t "$_kernelheaderdir"/certs "$_kernelobjectdir"/certs/signing_key.x509 || :

	make -C "$builddir" \
		O="$_kernelheaderdir" \
		ARCH="$_carch" \
		AWK="${AWK:-mawk}" \
		prepare modules_prepare scripts

	# remove the stuff that points to real sources. we want 3rd party
	# modules to believe this is the sources
	rm "$_kernelheaderdir"/Makefile "$_kernelheaderdir"/source

	# copy the needed stuff from real sources
	#
	# this is taken from ubuntu kernel build script
	# http://kernel.ubuntu.com/git/ubuntu/ubuntu-zesty.git/tree/debian/rules.d/3-binary-indep.mk
	cd "$builddir"

	find .  -path './include/*' -prune \
		-o -path './scripts/*' -prune -o -type f \
		\( -name 'Makefile*' -o -name 'Kconfig*' -o -name 'Kbuild*' -o \
		   -name '*.sh' -o -name '*.pl' -o -name '*.lds' -o -name 'Platform' \) \
		-print | cpio -pdm "$_kernelheaderdir"

	cp -a scripts include "$_kernelheaderdir"

	find "arch/$_carch" "tools/include" "tools/arch/$_carch" -type f -path '*/include/*' \
		-print | cpio -pdm "$_kernelheaderdir"

	install -Dm644 "$_kernelobjectdir"/Module.symvers \
		"$_kernelheaderdir"/Module.symvers

	# remove unneeded things
	msg "Removing documentation..."
	rm -r "$_kernelheaderdir"/Documentation
	sed -i -e '/Documentation/d' "$_kernelheaderdir"/Kconfig
	find "$_kernelheaderdir" -type f \( -name '*.o' -o -name '*.cmd' \) -exec rm -v -- {} +

	mkdir -p "$subpkgdir"/lib/modules/"$_abi_release"
	ln -sf /usr/src/linux-headers-"$_abi_release" \
		"$subpkgdir"/lib/modules/"$_abi_release"/build

}

