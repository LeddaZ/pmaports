# Reference: <https://postmarketos.org/devicepkg>
maintainer="Casey Connolly <casey.connolly@linaro.org>"
pkgname=device-qcom-sdm845
pkgdesc="Generic device package for Qualcomm SDM845 devices"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-sdm845
	firmware-oneplus-sdm845
	firmware-xiaomi-beryllium
	fwupd>=1.8.6
	hexagonrpcd
	linux-firmware-ath10k
	linux-firmware-qcom
	linux-postmarketos-qcom-sdm845
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-modem
	soc-qcom-pd-mapper
	soc-qcom-qbootctl
	systemd-boot
	unl0kr-fbforcerefresh
"
makedepends="devicepkg-dev"
subpackages="$pkgname-udev"
source="
	81-libssc-180-degrees.rules
	deviceinfo
	kernel-cmdline.conf
	modules-initfs
	q6voiced.conf
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/q6voiced.conf \
		"$pkgdir"/etc/conf.d/q6voiced

	install -Dm644 "$srcdir"/81-libssc-180-degrees.rules -t \
		"$pkgdir"/usr/lib/udev/rules.d
}

