cf950667d64c350d8660e1dcd7e22ae2a7e549ac1ad7319e851d79d7c20991ae9c838116d4ea4c58b1311cf52e1aae860b8ad795b86710c1dff2466002882e71  config-asus-tinker-board.armv7
"
