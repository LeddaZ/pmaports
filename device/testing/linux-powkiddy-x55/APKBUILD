b38ed4cfe0f20b440426c4ba55eb727cfa64f01370f22d7aca486df4f44aceec1c1d0790c29b8984b151bee0d3ef671253d220dc0c7bec9fef6a4ce1b6cf6169  rtw88_wifi_fix.patch
839566ba0c3c0b98b9f814a81805aa3911910d16e45ddef6a5c74562670ae88eda06213edd6595415886383161135514383c5f93044efa5b91a2f7b6f7854192  config-powkiddy-x55.aarch64
"
