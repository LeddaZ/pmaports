maintainer="Luca Weiss <luca@lucaweiss.eu>"
pkgname=alsa-ucm-conf-qcom-sc7280
pkgver=4
pkgrel=0
pkgdesc="ALSA UCM configuration for sc7280 devices"
url="https://github.com/bhush9/alsa-ucm-conf"
arch="aarch64"
license="BSD-3-Clause"
provides="alsa-ucm-conf"
provider_priority=1
_commit="3434f414509e2e6880d0b713015a34ebe43572b9"
source="$pkgname-$_commit.tar.gz::$url/archive/$_commit.tar.gz"
options="!check"
builddir="$srcdir/alsa-ucm-conf-$_commit"

package() {
	# install audio config files
	mkdir -p "$pkgdir"/usr/share/alsa
	cp -r ucm2 "$pkgdir"/usr/share/alsa/
}

